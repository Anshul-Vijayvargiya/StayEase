<% layout('/layouts/boilerplate') -%>
<body>

    <h3> Create a New List </h3>
    <form method="POST" action="/listings" novalidate class= "needs-validation" enctype="multipart/form-data">
        <br>
        <div class="mb-3">
            <label for="title" class="form-label"> Enter Title : </label>
    <input name="listing[title]" placeholder="enter title" type="text" class="form-control" required>
     <div class="invalid-feedback">
      Please provide a valid title.
    </div>

        </div>
    <br>

    <div class="mb-3">
         <label for="description"  class="form-label">Enter Description : </label>
    <textarea name="listing[description]" placeholder="Enter description" class="form-control"    required></textarea>
        <div class="invalid-feedback">
      Please provide a valid description.
    </div>

    </div>
   <br>

      <div class="mb-3">
          <label for="Image"  class="form-label">Image </label>
    <input name="listing[image]" placeholder="Enter image URL" type="file" class="form-control"
    required >
    </div>
  
  
   <br>
    <div class="mb-3">
  <label for="price " class="form-label"> Enter Price : </label>
    <input name="listing[price]"type="number"placeholder="Enter Price"  class="form-control" required>
        <div class="invalid-feedback">
      Please provide a valid price.
    </div>

    </div>
  <br>

    <div class="mb-3">
        <label for="location" class="form-label"> Enter Location : </label>
    <input name="listing[location]" placeholder="Enter location" type="text" class="form-control"  required>
        <div class="invalid-feedback">
      Please provide a valid location.
    </div>

    </div>

    <br>

    <div class="mb-3">
 <label for="title" class="form-label"> Enter Country Name  : </label>
    <input name="listing[country]" placeholder="Enter Country" type="text" class="form-control" required>
        <div class="invalid-feedback">
      Please provide a valid country.
    </div>
    </div>
   <br>
   
    <button class="btn btn-primary">Submit</button>
    
    </form>
<br>

</body>
